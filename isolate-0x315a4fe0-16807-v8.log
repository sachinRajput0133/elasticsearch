script-source,374,/home/knovator/personal/testcases/node_modules/iconv-lite/encodings/dbcs-data.js,"use strict";\n\n// Description of supported double byte encodings and aliases.\n// Tables are not require()-d until they are needed to speed up library load.\n// require()-s are direct to support Browserify.\n\nmodule.exports = {\n    \n    // == Japanese/ShiftJIS ====================================================\n    // All japanese encodings are based on JIS X set of standards:\n    // JIS X 0201 - Single-byte encoding of ASCII + \xa5 + Kana chars at 0xA1-0xDF.\n    // JIS X 0208 - Main set of 6879 characters\x2C placed in 94x94 plane\x2C to be encoded by 2 bytes. \n    //              Has several variations in 1978\x2C 1983\x2C 1990 and 1997.\n    // JIS X 0212 - Supplementary plane of 6067 chars in 94x94 plane. 1990. Effectively dead.\n    // JIS X 0213 - Extension and modern replacement of 0208 and 0212. Total chars: 11233.\n    //              2 planes\x2C first is superset of 0208\x2C second - revised 0212.\n    //              Introduced in 2000\x2C revised 2004. Some characters are in Unicode Plane 2 (0x2xxxx)\n\n    // Byte encodings are:\n    //  * Shift_JIS: Compatible with 0201\x2C uses not defined chars in top half as lead bytes for double-byte\n    //               encoding of 0208. Lead byte ranges: 0x81-0x9F\x2C 0xE0-0xEF; Trail byte ranges: 0x40-0x7E\x2C 0x80-0x9E\x2C 0x9F-0xFC.\n    //               Windows CP932 is a superset of Shift_JIS. Some companies added more chars\x2C notably KDDI.\n    //  * EUC-JP:    Up to 3 bytes per character. Used mostly on *nixes.\n    //               0x00-0x7F       - lower part of 0201\n    //               0x8E\x2C 0xA1-0xDF - upper part of 0201\n    //               (0xA1-0xFE)x2   - 0208 plane (94x94).\n    //               0x8F\x2C (0xA1-0xFE)x2 - 0212 plane (94x94).\n    //  * JIS X 208: 7-bit\x2C direct encoding of 0208. Byte ranges: 0x21-0x7E (94 values). Uncommon.\n    //               Used as-is in ISO2022 family.\n    //  * ISO2022-JP: Stateful encoding\x2C with escape sequences to switch between ASCII\x2C \n    //                0201-1976 Roman\x2C 0208-1978\x2C 0208-1983.\n    //  * ISO2022-JP-1: Adds esc seq for 0212-1990.\n    //  * ISO2022-JP-2: Adds esc seq for GB2313-1980\x2C KSX1001-1992\x2C ISO8859-1\x2C ISO8859-7.\n    //  * ISO2022-JP-3: Adds esc seq for 0201-1976 Kana set\x2C 0213-2000 Planes 1\x2C 2.\n    //  * ISO2022-JP-2004: Adds 0213-2004 Plane 1.\n    //\n    // After JIS X 0213 appeared\x2C Shift_JIS-2004\x2C EUC-JISX0213 and ISO2022-JP-2004 followed\x2C with just changing the planes.\n    //\n    // Overall\x2C it seems that it's a mess :( http://www8.plala.or.jp/tkubota1/unicode-symbols-map2.html\n\n    'shiftjis': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/shiftjis.json') }\x2C\n        encodeAdd: {'\\u00a5': 0x5C\x2C '\\u203E': 0x7E}\x2C\n        encodeSkipVals: [{from: 0xED40\x2C to: 0xF940}]\x2C\n    }\x2C\n    'csshiftjis': 'shiftjis'\x2C\n    'mskanji': 'shiftjis'\x2C\n    'sjis': 'shiftjis'\x2C\n    'windows31j': 'shiftjis'\x2C\n    'ms31j': 'shiftjis'\x2C\n    'xsjis': 'shiftjis'\x2C\n    'windows932': 'shiftjis'\x2C\n    'ms932': 'shiftjis'\x2C\n    '932': 'shiftjis'\x2C\n    'cp932': 'shiftjis'\x2C\n\n    'eucjp': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/eucjp.json') }\x2C\n        encodeAdd: {'\\u00a5': 0x5C\x2C '\\u203E': 0x7E}\x2C\n    }\x2C\n\n    // TODO: KDDI extension to Shift_JIS\n    // TODO: IBM CCSID 942 = CP932\x2C but F0-F9 custom chars and other char changes.\n    // TODO: IBM CCSID 943 = Shift_JIS = CP932 with original Shift_JIS lower 128 chars.\n\n\n    // == Chinese/GBK ==========================================================\n    // http://en.wikipedia.org/wiki/GBK\n    // We mostly implement W3C recommendation: https://www.w3.org/TR/encoding/#gbk-encoder\n\n    // Oldest GB2312 (1981\x2C ~7600 chars) is a subset of CP936\n    'gb2312': 'cp936'\x2C\n    'gb231280': 'cp936'\x2C\n    'gb23121980': 'cp936'\x2C\n    'csgb2312': 'cp936'\x2C\n    'csiso58gb231280': 'cp936'\x2C\n    'euccn': 'cp936'\x2C\n\n    // Microsoft's CP936 is a subset and approximation of GBK.\n    'windows936': 'cp936'\x2C\n    'ms936': 'cp936'\x2C\n    '936': 'cp936'\x2C\n    'cp936': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/cp936.json') }\x2C\n    }\x2C\n\n    // GBK (~22000 chars) is an extension of CP936 that added user-mapped chars and some other.\n    'gbk': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/cp936.json').concat(require('./tables/gbk-added.json')) }\x2C\n    }\x2C\n    'xgbk': 'gbk'\x2C\n    'isoir58': 'gbk'\x2C\n\n    // GB18030 is an algorithmic extension of GBK.\n    // Main source: https://www.w3.org/TR/encoding/#gbk-encoder\n    // http://icu-project.org/docs/papers/gb18030.html\n    // http://source.icu-project.org/repos/icu/data/trunk/charset/data/xml/gb-18030-2000.xml\n    // http://www.khngai.com/chinese/charmap/tblgbk.php?page=0\n    'gb18030': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/cp936.json').concat(require('./tables/gbk-added.json')) }\x2C\n        gb18030: function() { return require('./tables/gb18030-ranges.json') }\x2C\n        encodeSkipVals: [0x80]\x2C\n        encodeAdd: {'\u20ac': 0xA2E3}\x2C\n    }\x2C\n\n    'chinese': 'gb18030'\x2C\n\n\n    // == Korean ===============================================================\n    // EUC-KR\x2C KS_C_5601 and KS X 1001 are exactly the same.\n    'windows949': 'cp949'\x2C\n    'ms949': 'cp949'\x2C\n    '949': 'cp949'\x2C\n    'cp949': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/cp949.json') }\x2C\n    }\x2C\n\n    'cseuckr': 'cp949'\x2C\n    'csksc56011987': 'cp949'\x2C\n    'euckr': 'cp949'\x2C\n    'isoir149': 'cp949'\x2C\n    'korean': 'cp949'\x2C\n    'ksc56011987': 'cp949'\x2C\n    'ksc56011989': 'cp949'\x2C\n    'ksc5601': 'cp949'\x2C\n\n\n    // == Big5/Taiwan/Hong Kong ================================================\n    // There are lots of tables for Big5 and cp950. Please see the following links for history:\n    // http://moztw.org/docs/big5/  http://www.haible.de/bruno/charsets/conversion-tables/Big5.html\n    // Variations\x2C in roughly number of defined chars:\n    //  * Windows CP 950: Microsoft variant of Big5. Canonical: http://www.unicode.org/Public/MAPPINGS/VENDORS/MICSFT/WINDOWS/CP950.TXT\n    //  * Windows CP 951: Microsoft variant of Big5-HKSCS-2001. Seems to be never public. http://me.abelcheung.org/articles/research/what-is-cp951/\n    //  * Big5-2003 (Taiwan standard) almost superset of cp950.\n    //  * Unicode-at-on (UAO) / Mozilla 1.8. Falling out of use on the Web. Not supported by other browsers.\n    //  * Big5-HKSCS (-2001\x2C -2004\x2C -2008). Hong Kong standard. \n    //    many unicode code points moved from PUA to Supplementary plane (U+2XXXX) over the years.\n    //    Plus\x2C it has 4 combining sequences.\n    //    Seems that Mozilla refused to support it for 10 yrs. https://bugzilla.mozilla.org/show_bug.cgi?id=162431 https://bugzilla.mozilla.org/show_bug.cgi?id=310299\n    //    because big5-hkscs is the only encoding to include astral characters in non-algorithmic way.\n    //    Implementations are not consistent within browsers; sometimes labeled as just big5.\n    //    MS Internet Explorer switches from big5 to big5-hkscs when a patch applied.\n    //    Great discussion & recap of what's going on https://bugzilla.mozilla.org/show_bug.cgi?id=912470#c31\n    //    In the encoder\x2C it might make sense to support encoding old PUA mappings to Big5 bytes seq-s.\n    //    Official spec: http://www.ogcio.gov.hk/en/business/tech_promotion/ccli/terms/doc/2003cmp_2008.txt\n    //                   http://www.ogcio.gov.hk/tc/business/tech_promotion/ccli/terms/doc/hkscs-2008-big5-iso.txt\n    // \n    // Current understanding of how to deal with Big5(-HKSCS) is in the Encoding Standard\x2C http://encoding.spec.whatwg.org/#big5-encoder\n    // Unicode mapping (http://www.unicode.org/Public/MAPPINGS/OBSOLETE/EASTASIA/OTHER/BIG5.TXT) is said to be wrong.\n\n    'windows950': 'cp950'\x2C\n    'ms950': 'cp950'\x2C\n    '950': 'cp950'\x2C\n    'cp950': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/cp950.json') }\x2C\n    }\x2C\n\n    // Big5 has many variations and is an extension of cp950. We use Encoding Standard's as a consensus.\n    'big5': 'big5hkscs'\x2C\n    'big5hkscs': {\n        type: '_dbcs'\x2C\n        table: function() { return require('./tables/cp950.json').concat(require('./tables/big5-added.json')) }\x2C\n        encodeSkipVals: [0xa2cc]\x2C\n    }\x2C\n\n    'cnbig5': 'big5hkscs'\x2C\n    'csbig5': 'big5hkscs'\x2C\n    'xxbig5': 'big5hkscs'\x2C\n};\n
