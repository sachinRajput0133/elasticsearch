script-source,282,/home/knovator/personal/testcases/node_modules/jws/lib/sign-stream.js,/*global module*/\nvar Buffer = require('safe-buffer').Buffer;\nvar DataStream = require('./data-stream');\nvar jwa = require('jwa');\nvar Stream = require('stream');\nvar toString = require('./tostring');\nvar util = require('util');\n\nfunction base64url(string\x2C encoding) {\n  return Buffer\n    .from(string\x2C encoding)\n    .toString('base64')\n    .replace(/=/g\x2C '')\n    .replace(/\\+/g\x2C '-')\n    .replace(/\\//g\x2C '_');\n}\n\nfunction jwsSecuredInput(header\x2C payload\x2C encoding) {\n  encoding = encoding || 'utf8';\n  var encodedHeader = base64url(toString(header)\x2C 'binary');\n  var encodedPayload = base64url(toString(payload)\x2C encoding);\n  return util.format('%s.%s'\x2C encodedHeader\x2C encodedPayload);\n}\n\nfunction jwsSign(opts) {\n  var header = opts.header;\n  var payload = opts.payload;\n  var secretOrKey = opts.secret || opts.privateKey;\n  var encoding = opts.encoding;\n  var algo = jwa(header.alg);\n  var securedInput = jwsSecuredInput(header\x2C payload\x2C encoding);\n  var signature = algo.sign(securedInput\x2C secretOrKey);\n  return util.format('%s.%s'\x2C securedInput\x2C signature);\n}\n\nfunction SignStream(opts) {\n  var secret = opts.secret;\n  secret = secret == null ? opts.privateKey : secret;\n  secret = secret == null ? opts.key : secret;\n  if (/^hs/i.test(opts.header.alg) === true && secret == null) {\n    throw new TypeError('secret must be a string or buffer or a KeyObject')\n  }\n  var secretStream = new DataStream(secret);\n  this.readable = true;\n  this.header = opts.header;\n  this.encoding = opts.encoding;\n  this.secret = this.privateKey = this.key = secretStream;\n  this.payload = new DataStream(opts.payload);\n  this.secret.once('close'\x2C function () {\n    if (!this.payload.writable && this.readable)\n      this.sign();\n  }.bind(this));\n\n  this.payload.once('close'\x2C function () {\n    if (!this.secret.writable && this.readable)\n      this.sign();\n  }.bind(this));\n}\nutil.inherits(SignStream\x2C Stream);\n\nSignStream.prototype.sign = function sign() {\n  try {\n    var signature = jwsSign({\n      header: this.header\x2C\n      payload: this.payload.buffer\x2C\n      secret: this.secret.buffer\x2C\n      encoding: this.encoding\n    });\n    this.emit('done'\x2C signature);\n    this.emit('data'\x2C signature);\n    this.emit('end');\n    this.readable = false;\n    return signature;\n  } catch (e) {\n    this.readable = false;\n    this.emit('error'\x2C e);\n    this.emit('close');\n  }\n};\n\nSignStream.sign = jwsSign;\n\nmodule.exports = SignStream;\n
