event\x2C handler\x2C flags) {\n      eventTargetAgnosticAddListener(emitter\x2C event\x2C handler\x2C flags);\n      ArrayPrototypePush(listeners\x2C [emitter\x2C event\x2C handler\x2C flags]);\n    }\x2C\n    removeAll() {\n      while (listeners.length > 0) {\n        ReflectApply(eventTargetAgnosticRemoveListener\x2C undefined\x2C ArrayPrototypePop(listeners));\n      }\n    }\x2C\n  };\n}\n
