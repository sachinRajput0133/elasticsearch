rs[protocol](url\x2C context\x2C true);\n}\n\n/**\n * @param {URL} url\n * @param {{parentURL: string}} context\n * @returns {Promise<string> | string | undefined} only works when enabled\n */\nfunction defaultGetFormat(url\x2C context) {\n  const protocol = url.protocol;\n  if (!ObjectPrototypeHasOwnProperty(protocolHandlers\x2C protocol)) {\n    return null;\n  }\n  return protocolHandlers[protocol](url\x2C context\x2C false);\n}\n\nmodule.exports = {\n  defaultGetFormat\x2C\n  defaultGetFormatWithoutErrors\x2C\n  extensionFormatMap\x2C\n  extname\x2C\n};\n
