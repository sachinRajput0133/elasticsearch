script-source,303,/home/knovator/personal/testcases/node_modules/jsonwebtoken/node_modules/semver/internal/identifiers.js,'use strict'\n\nconst numeric = /^[0-9]+$/\nconst compareIdentifiers = (a\x2C b) => {\n  if (typeof a === 'number' && typeof b === 'number') {\n    return a === b ? 0 : a < b ? -1 : 1\n  }\n\n  const anum = numeric.test(a)\n  const bnum = numeric.test(b)\n\n  if (anum && bnum) {\n    a = +a\n    b = +b\n  }\n\n  return a === b ? 0\n    : (anum && !bnum) ? -1\n    : (bnum && !anum) ? 1\n    : a < b ? -1\n    : 1\n}\n\nconst rcompareIdentifiers = (a\x2C b) => compareIdentifiers(b\x2C a)\n\nmodule.exports = {\n  compareIdentifiers\x2C\n  rcompareIdentifiers\x2C\n}\n
