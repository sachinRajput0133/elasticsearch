script-source,275,/home/knovator/personal/testcases/src/routes/auth.js,const express = require('express');\nconst router = express.Router();\nconst { register\x2C login } = require('../controllers/authController');\nconst { slowEndpoint\x2C fastEndpoint } = require('../controllers/demoController');\n\nrouter.post('/register'\x2C register);\nrouter.post('/login'\x2C login);\n\n// Profiling demo routes\nrouter.get('/demo/slow'\x2C slowEndpoint);\nrouter.get('/demo/fast'\x2C fastEndpoint);\n\nmodule.exports = router;\n
