script-source,352,/home/knovator/personal/testcases/src/store/userStore.js,// In-memory user store (simulates a database)\nconst users = [];\n\nconst findByEmail = (email) => users.find((u) => u.email === email);\n\nconst create = (user) => {\n  users.push(user);\n  return user;\n};\n\nconst clear = () => {\n  users.length = 0;\n};\n\nmodule.exports = { findByEmail\x2C create\x2C clear };\n
