script-source,82,/home/knovator/personal/testcases/src/app.js,const express = require('express');\nconst authRoutes = require('./routes/auth');\n\nconst app = express();\n\napp.use(express.json());\n\n// Request logger\napp.use((req\x2C res\x2C next) => {\n  const start = Date.now();\n  res.on('finish'\x2C () => {\n    console.log(`[${new Date().toISOString()}] ${req.method} ${req.url} \u2192 ${res.statusCode} (${Date.now() - start}ms)`);\n  });\n  next();\n});\n\napp.use('/api/auth'\x2C authRoutes);\n\napp.get('/health'\x2C (req\x2C res) => res.status(200).json({ status: 'ok' }));\n\nmodule.exports = app;\n
