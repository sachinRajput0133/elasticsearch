script-source,276,/home/knovator/personal/testcases/src/controllers/authController.js,const bcrypt = require('bcryptjs');\nconst jwt = require('jsonwebtoken');\nconst userStore = require('../store/userStore');\n\nconst JWT_SECRET = process.env.JWT_SECRET || 'test_secret_key';\n\nconst register = async (req\x2C res) => {\n  const { name\x2C email\x2C password } = req.body;\n\n  if (!name || !email || !password) {\n    return res.status(400).json({ message: 'name\x2C email and password are required' });\n  }\n\n  const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  if (!emailRegex.test(email)) {\n    return res.status(400).json({ message: 'Invalid email format' });\n  }\n\n  if (password.length < 6) {\n    return res.status(400).json({ message: 'Password must be at least 6 characters' });\n  }\n\n  if (userStore.findByEmail(email)) {\n    return res.status(409).json({ message: 'Email already registered' });\n  }\n\n  const hashedPassword = await bcrypt.hash(password\x2C 10);\n  const user = userStore.create({ name\x2C email\x2C password: hashedPassword });\n\n  return res.status(201).json({ message: 'User registered successfully'\x2C user: { name: user.name\x2C email: user.email } });\n};\n\nconst login = async (req\x2C res) => {\n  const { email\x2C password } = req.body;\n\n  if (!email || !password) {\n    return res.status(400).json({ message: 'email and password are required' });\n  }\n\n  const user = userStore.findByEmail(email);\n  if (!user) {\n    return res.status(401).json({ message: 'Invalid credentials' });\n  }\n\n  const isMatch = await bcrypt.compare(password\x2C user.password);\n  if (!isMatch) {\n    return res.status(401).json({ message: 'Invalid credentials' });\n  }\n\n  const token = jwt.sign({ email: user.email\x2C name: user.name }\x2C JWT_SECRET\x2C { expiresIn: '1h' });\n\n  return res.status(200).json({ message: 'Login successful'\x2C token });\n};\n\nmodule.exports = { register\x2C login };\n
