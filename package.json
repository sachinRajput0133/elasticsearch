{
  "name": "auth-testcases",
  "version": "1.0.0",
  "description": "Register/Login API with Jest test cases",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "test:ci": "jest --ci --forceExit --detectOpenHandles --reporters=default"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
